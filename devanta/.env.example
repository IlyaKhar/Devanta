POSTGRES_DB=devanta
POSTGRES_USER=devanta
POSTGRES_PASSWORD=devanta
DATABASE_URL=postgres://devanta:devanta@postgres:5432/devanta?sslmode=disable
JWT_SECRET=super_secret_change_me
APP_ENV=development
CORS_ORIGIN=http://localhost:5173
# Публичный URL фронта для ссылки «подключить родителя» (docker/nginx: http://localhost). Если пусто — берётся из Host запроса.
PUBLIC_APP_URL=
SUPPORT_TELEGRAM_BOT_TOKEN=replace_with_telegram_bot_token
# Telegram user IDs админов, через запятую. Пример: 123456789,987654321
SUPPORT_ADMINS=
SUPPORT_BOT_PORT=8090
SUPPORT_ABOUT_TEXT=Devanta — образовательная платформа для детей 7–15 лет. Напиши сюда, если нужна помощь.

# Режим обновлений бота:
# - если SUPPORT_WEBHOOK_PUBLIC_URL ПУСТОЙ → long poll (работает локально без публичного URL)
# - если SUPPORT_WEBHOOK_PUBLIC_URL ЗАДАН → webhook (нужен публичный HTTPS домен/туннель)
# Пример: https://your-domain.com (без слеша в конце)
SUPPORT_WEBHOOK_PUBLIC_URL=
# Путь webhook. Должен совпадать в nginx и в настройке webhook Telegram.
SUPPORT_WEBHOOK_PATH=/telegram/webhook
# Защита webhook запросов от Telegram (X-Telegram-Bot-Api-Secret-Token)
SUPPORT_WEBHOOK_SECRET_TOKEN=
